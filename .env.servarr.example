# =========================================================================
# Media-acquisition stack config — Phase 5.0
# =========================================================================
# Copy to `.env.servarr` and edit for your host:
#     cp .env.servarr.example .env.servarr
# Then bring the stack up with:
#     docker compose -f docker-compose.servarr.yml --env-file .env.servarr up -d
#
# NO REAL SECRETS OR API KEYS BELONG IN THIS FILE. It is a committed template.
# The *_API_KEY / *_USER / *_PASS values below are placeholders that the app
# consumes in later phases — put the real ones in `.env.local` (gitignored),
# NOT here. See deploy/README-servarr.md.
# =========================================================================

# --- Container identity ---------------------------------------------------
# Run `id` on the host to get your UID/GID. Files created by the containers
# will be owned by these so the app / your user can read them.
PUID=1000
PGID=1000
TZ=UTC

# --- Host paths -----------------------------------------------------------
# CONFIG_ROOT: where each service persists its own /config (DB, settings).
CONFIG_ROOT=./servarr-config
#
# MEDIA_ROOT: the SINGLE host tree mounted as /data in the media containers.
# Downloads AND the final library live under here so hardlinks/atomic-moves
# work (see README "Why one /data mount"). Point Jellyfin at the same tree.
# Expected layout under this root:
#     <MEDIA_ROOT>/downloads       (qBittorrent save path -> /data/downloads)
#     <MEDIA_ROOT>/media/movies    (Radarr root  -> /data/media/movies)
#     <MEDIA_ROOT>/media/tv        (Sonarr root  -> /data/media/tv)
MEDIA_ROOT=./media-data
#
# Informational: subpaths INSIDE the containers (all under /data). You
# generally set these in each service's UI, not here — listed for reference.
DOWNLOADS_ROOT=/data/downloads
MOVIES_ROOT=/data/media/movies
TV_ROOT=/data/media/tv

# --- Host ports (published on the host) -----------------------------------
# Chosen to avoid colliding with the app (3000/3001), Jellyfin (8096),
# and LiveKit (7880-7882). Change if any conflict on your host.
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
BAZARR_PORT=6767
QBITTORRENT_PORT=8080
# BitTorrent listen port (TCP+UDP). Forward on router/VPS for better peers.
QBITTORRENT_BT_PORT=6881

# --- Docker network -------------------------------------------------------
# Internal network name. To share with the app/Jellyfin compose, see README.
SERVARR_NETWORK=watchparty-servarr

# =========================================================================
# App-side integration placeholders (consumed in Phase 5.1+).
# These live in .env.local for real; template only here.
#
# URLs: use container names if the app shares the servarr network
#   (e.g. http://sonarr:8989), or http://<host>:<port> if the app runs on
#   the host / a different network.
#
# API keys: NOT set here. Each service generates one on first run under
#   Settings -> General -> Security -> API Key. Copy it into .env.local.
#   qBittorrent has no API key — it uses WebUI username/password instead.
# =========================================================================
SONARR_URL=http://localhost:8989
SONARR_API_KEY=

RADARR_URL=http://localhost:7878
RADARR_API_KEY=

BAZARR_URL=http://localhost:6767
BAZARR_API_KEY=

PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=

QBITTORRENT_URL=http://localhost:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=
