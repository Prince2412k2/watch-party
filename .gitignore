# livekit.yaml holds the real LiveKit API key:secret — keep it out of git.
# Commit livekit.yaml.example (placeholders) instead. NOTE: livekit.yaml was
# already tracked in a prior commit, so to actually stop tracking the real
# secret run once:  git rm --cached livekit.yaml
livekit.yaml
