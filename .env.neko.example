# Local Neko demo values — merge these into the repo-root .env (gitignored).
# I could not write/edit .env directly: it is covered by a permission
# deny-rule in this environment (both .env and .env.local are blocked for
# Read/Edit/Bash). Please append/merge the lines below into your .env by hand.

NEKO_ENABLED=true
NEKO_RECREATE_MODE=noop
NEKO_INTERNAL_URL=http://neko:8080
NEKO_PUBLIC_WS=/neko
NEKO_API_TOKEN=local-demo-api-token-0001
NEKO_USER_PASSWORD=neko
NEKO_USERNAME_SECRET=local-demo-username-secret-000
NEKO_IDLE_TIMEOUT_MS=300000
NEKO_SSH_HOST=
NEKO_SSH_KEY_PATH=

# neko service side:
NEKO_SESSION_API_TOKEN=local-demo-api-token-0001
NEKO_MEMBER_MULTIUSER_USER_PASSWORD=neko
NEKO_MEMBER_MULTIUSER_ADMIN_PASSWORD=admin
NEKO_WEBRTC_NAT1TO1=127.0.0.1
NEKO_WEBRTC_EPR=56000-56100
