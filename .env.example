# Committed template for the unified docker-compose stack. NO REAL SECRETS.
# Copy real values into .env / .env.local (both gitignored).
#
# Two kinds of URLs — keep them straight:
#   * INTERNAL (server → service): docker container names, resolved on the
#     shared watchparty-net. Never sent to the browser. docker-compose.yml pins
#     these in the app service's `environment:` block, so they always win.
#   * PUBLIC (browser → service): must be reachable from the END USER's machine.

# ── Server → service (INTERNAL container names) ──
JELLYFIN_URL=http://jellyfin:8096
LIVEKIT_URL=ws://livekit:7880
# Servarr stack (only needed by the app server; keys live in .env.local):
SONARR_URL=http://sonarr:8989
RADARR_URL=http://radarr:7878
PROWLARR_URL=http://prowlarr:9696
BAZARR_URL=http://bazarr:6767
QBITTORRENT_URL=http://qbittorrent:8080

# ── Browser → LiveKit signaling (PUBLIC, host-reachable) ──
# Handed to the browser by /api/livekit/token. Do NOT use ws://livekit:7880.
#   * Plain/local HTTP:  ws://localhost:7880   (or ws://<host-ip>:7880)
#   * Behind HTTPS:      wss://<your-host>/livekit  (app proxies -> livekit:7880)
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Extra allowed CORS/browser origin(s), comma-separated. localhost:5173/5174
# (Vite dev) and the tailnet origin are always allowed; add others here.
PUBLIC_ORIGIN=

# Optional cookie domain for sharing auth across subdomains.
# Example: .sniffkin.tech
SESSION_COOKIE_DOMAIN=

# ── LiveKit keys (server-side token signing) ──
# Generate a secret with:  openssl rand -hex 32   (key can be shorter, e.g. -hex 16).
# The key:secret pair here MUST match the `keys:` entry in livekit.yaml.
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME

# Generate with:  openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# TURN — leave blank for local dev, fill in when deploying
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Real secrets below belong in .env.local (gitignored), NOT here:
#   SONARR_API_KEY=...
#   RADARR_API_KEY=...
#   PROWLARR_API_KEY=...
#   BAZARR_API_KEY=...
#   QBITTORRENT_USER=admin
#   QBITTORRENT_PASS=...
# (Service *_URL values are pinned by compose to container names, so .env.local
#  only needs the keys/creds — do not re-set the URLs to localhost there.)
