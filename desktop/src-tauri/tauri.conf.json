{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watchparty",
  "version": "0.1.0",
  "identifier": "com.watchparty.desktop",
  "build": {
    "devUrl": "https://dsk-4161.tail0a3558.ts.net",
    "frontendDist": "../../app/client/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Watchparty",
        "url": "https://dsk-4161.tail0a3558.ts.net",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": ["https://example.invalid/updater/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": ""
    }
  }
}
