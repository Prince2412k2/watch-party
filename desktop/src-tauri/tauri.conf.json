{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watchparty",
  "version": "0.1.0",
  "identifier": "com.watchparty.desktop",
  "build": {
    "devUrl": "http://localhost:5183",
    "frontendDist": "../../app/client/dist",
    "beforeDevCommand": {
      "script": "npm run dev -- --port 5183 --strictPort",
      "cwd": "../../app/client"
    },
    "beforeBuildCommand": "npm run build --prefix ../../app/client"
  },
  "app": {
    "windows": [
      {
        "title": "Watchparty",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
